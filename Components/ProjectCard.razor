@using Portafolio.Models
@using Portafolio.Data
@namespace Portafolio.Components
@inject Portafolio.Services.LanguageService LangSvc
@implements IDisposable

<article class="project-card @(Proyecto.Destacado ? "featured" : "")">
    <div class="project-image">
        <img src="@Proyecto.Imagen" alt="@Proyecto.Titulo" loading="lazy" decoding="async"
             onerror="this.onerror=null;this.src='/images/default.svg'" />
    </div>

    <div class="project-body">
        <div class="project-meta">
            <span class="project-status status-@Proyecto.Estado">@EstadoLabel</span>
            <span class="project-period">@Proyecto.Periodo</span>
        </div>

        <h3 class="project-title">@Proyecto.Titulo</h3>
        <p class="project-desc">@Proyecto.DescripcionCorta</p>

        <div class="project-stack">
            @foreach (var tech in Proyecto.Stack.Take(6))
            {
                <span class="tech-badge">@tech</span>
            }
        </div>

        <div class="project-footer">
            <a href="@Proyecto.UrlRepositorio" target="_blank" rel="noopener"
               class="btn btn-primary">
                <span>@LangSvc.T("card.verCodigo")</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.17c-3.34.72-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23.96-.27 1.98-.4 3-.4s2.04.13 3 .4c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
            </a>
            @if (!string.IsNullOrEmpty(Proyecto.UrlDemo))
            {
                <a href="@Proyecto.UrlDemo" target="_blank" rel="noopener" class="btn btn-secondary">
                    <span>@LangSvc.T("card.demo")</span>
                </a>
            }
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public Proyecto Proyecto { get; set; } = default!;

    private string EstadoLabel => Proyecto.Estado switch
    {
        "completed" => LangSvc.T("estado.completado"),
        "wip" => LangSvc.T("estado.wip"),
        "archived" => LangSvc.T("estado.archived"),
        _ => Proyecto.Estado
    };

    protected override void OnInitialized() => LangSvc.OnChange += HandleChange;
    public void Dispose() => LangSvc.OnChange -= HandleChange;
    private void HandleChange() => InvokeAsync(StateHasChanged);
}
